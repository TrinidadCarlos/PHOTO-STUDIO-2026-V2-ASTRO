---
import Layout from "@layouts/Layout.astro";
import "@styles/pages/services/homeServices.css";
import "@styles/pages/reviews.css";

import { Image } from "astro:assets";
import photoFace from "@assets/img/generic/face.png";
---

<Layout>
    <main class={`t-100vh t-padding-header main-reviews-page`}>
        <h1 class={`t-page-titles reviews-title-page`}>COMENTARIOS</h1>
        <h4 class={`service-subtitle`}>
            Algunos de los comentarios de nuestros clientes
        </h4>

        <section class="review-container">
            <div class="swiper mySwiper-reviews">
                <div class="swiper-wrapper swiper-wrapper-reviews">
                    {
                        [
                            { service: "Bodas", user: "Roberto Gómez", comment: "Excelente atención y fotografías increíbles. Lograron capturar la esencia de nuestro día perfectamente." },
                            { service: "Familia", user: "María Hernández", comment: "Una experiencia maravillosa. Nos hicieron sentir muy cómodos en el estudio y las fotos salieron preciosas." },
                            { service: "Eventos", user: "Carlos López", comment: "La puntualidad y profesionalismo son excepcionales. Definitivamente los volvería a contratar para mi próximo evento." },
                            { service: "Maternidad", user: "Laura Sánchez", comment: "Qué belleza de sesión. Tuvieron muchísima paciencia y capturaron una etapa tan especial de una forma mágica." },
                            { service: "Bodas", user: "Ana y Pedro", comment: "El álbum superó nuestras expectativas. Tienen un ojo increíble para los detalles. Totalmente recomendados." },
                            { service: "Mascotas", user: "Diego Torres", comment: "Mi perro no paraba de moverse y aún así consiguieron fotos espectaculares. Son unos magos con las mascotas." },
                            { service: "Negocio", user: "Empresa XYZ", comment: "Renovamos las fotos corporativas de todo el equipo. Resultados impecables, muy profesionales y rápidos." },
                            { service: "Parejas", user: "Sofía y Luis", comment: "Nos divertimos mucho durante la sesión en exteriores. Las fotos tienen un toque muy cinemático que nos encantó." }
                        ].map(review => (
                            <div class="swiper-slide slide-reviews">
                                <div class="card-review">
                                    <div class="card-quote">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="32" height="32" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                                    </div>
                                    <div class="card-body">
                                        <p>"{review.comment}"</p>
                                    </div>
                                    <div class="card-footer">
                                        <div class="card-header">
                                            <figure>
                                                <Image
                                                    src={photoFace}
                                                    alt="Imagen representativa de un cliente"
                                                    loading="lazy"
                                                />
                                            </figure>
                                            <div>
                                                <p class="card-service-user">{review.user}</p>
                                                <p class="card-service-name">{review.service}</p>
                                                <div class="stars">
                                                    {[1,2,3,4,5].map(() => (
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/></svg>
                                                    ))}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>
                <div class="swiper-pagination swiper-pagination-reviews"></div>
            </div>
        </section>
    </main>
</Layout>

<script>
    import Swiper from "swiper/bundle";

    const swiper = new Swiper(".mySwiper-reviews", {
        // direction: "vertical",
        effect: "slide",
        fadeEffect: {
            crossFade: true,
        },
        loop: true,

        autoplay: {
            delay: 250000,
        },

        breakpoints: {
            640: {
                slidesPerView: 2,
                spaceBetween: 40,
                grid: {
                    rows: 2,
                    fill: "row",
                },
            },
            1024: {
                slidesPerView: 2,
                spaceBetween: 40,
                grid: {
                    rows: 2,
                    fill: "row",
                },
            },
        },
        // If we need pagination
        pagination: {
            el: ".swiper-pagination-reviews",
            clickable: true,
        },

        // Navigation arrows
        // navigation: {
        //   nextEl: '.swiper-button-next',
        //   prevEl: '.swiper-button-prev',
        // },

        // And if we need scrollbar
        // scrollbar: {
        //   el: ".swiper-scrollbar",
        // },
    });
</script>
