---
import Layout from "@layouts/Layout.astro";
import "@styles/pages/gallery/homeGallery.css";
import { routes } from "@utils/constants/routes";

import bussinessImage from "@assets/img/services/bussiness-one.jpg";
import familyImage from "@assets/img/services/family-one.jpg";
import petsImage from "@assets/img/services/pets-one.jpg";
import maternityImage from "@assets/img/services/maternity-one.jpg";
import eventsImage from "@assets/img/services/events-one.jpg";
import couplesImage from "@assets/img/services/couples-one.jpg";
import religiousImage from "@assets/img/services/religious-one.jpg";
import weddingImage from "@assets/img/services/wedding-one.jpg";
import emptyImage from "@assets/img/generic/services-menu.jpg";
import { Image } from "astro:assets";

const images = {
    "family-one": familyImage,
    "pets-one": petsImage,
    "bussiness-one": bussinessImage,
    "events-one": eventsImage,
    "couples-one": couplesImage,
    "religious-one": religiousImage,
    "wedding-one": weddingImage,
    "maternity-one": maternityImage,
};
const galleryRoutes = routes.filter((router) => router.basePath == "/gallery");

const descriptions = {
    "Bodas": "Momentos eternos capturados en tu gran día.",
    "Eventos religiosos": "La fe y la espiritualidad en cada imagen.",
    "Familia": "Tus seres queridos, creando recuerdos invaluables.",
    "Negocio": "Fotografía corporativa que eleva tu marca profesional.",
    "Eventos": "Fiestas, XV años y celebraciones inolvidables.",
    "Maternidad": "La belleza y la magia de la dulce espera.",
    "Parejas": "Historias de amor contadas a través de nuestro lente.",
    "Mascotas": "La alegría y lealtad de tus mejores amigos.",
};
---

<Layout>
    <main class="main-gallery-page">
        <!-- HERO SECTION -->
        <section class="page-hero t-padding-header" data-aos="fade-down">
            <div class="page-hero-content">
                <span class="page-subtitle">Nuestro Trabajo</span>
                <h1 class="t-page-titles">COLECCIONES</h1>
                <p class="gallery-intro">
                    Explora nuestros portafolios y sumérgete en las historias que hemos tenido el honor de documentar. Selecciona un álbum para abrir su galería.
                </p>
            </div>
        </section>

        <!-- GALLERY GRID OVERLAP -->
        <section class="page-overlap-content gallery-container" data-aos="fade-up" data-aos-delay="200">
            {
                galleryRoutes.map((routes) =>
                    routes.routes.map(
                        (route, idx) =>
                            route.path !== "" && (
                                <a href={`${routes.basePath}${route.path}`} class="gallery-album-card" data-aos="fade-up" data-aos-delay={idx * 100}>
                                    <figure>
                                        <Image
                                            src={
                                                route?.imgName
                                                    ? images[route.imgName as keyof typeof images]
                                                    : emptyImage
                                            }
                                            alt={`Álbum fotográfico de ${route.name}`}
                                            loading="lazy"
                                        />
                                    </figure>
                                    <div class="album-info">
                                        <h3>{route.name}</h3>
                                        <p class="album-desc">{descriptions[route.name as keyof typeof descriptions] || "Descubre esta colección de fotografías."}</p>
                                        <span class="album-link-btn">
                                            Abrir Álbum
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
                                                <path d="M14 5l7 7m0 0l-7 7m7-7H3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            </svg>
                                        </span>
                                    </div>
                                </a>
                            ),
                    ),
                )
            }
        </section>
    </main>
</Layout>
