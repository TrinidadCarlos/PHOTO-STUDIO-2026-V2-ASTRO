---
import LayoutGallery from "@layouts/LayoutGallery.astro";
import GalleryComponent, {
    type GalleryI,
} from "@components/GalleryComponent.tsx";

export function getStaticPaths() {
    return [
        { params: { sessionName: "weddings" } },
        { params: { sessionName: "family" } },
        { params: { sessionName: "pets" } },
        { params: { sessionName: "events" } },
        { params: { sessionName: "religious_events" } },
        { params: { sessionName: "maternity" } },
        { params: { sessionName: "couples" } },
        { params: { sessionName: "business" } },
    ];
}

const titlesLayout = {
    weddings: {
        title: "Bodas",
        subtitle: "Un sí que vive para siempre",
    },
    religious_events: {
        title: "Eventos Religiosos",
        subtitle: "Fe, tradición y momentos eternos",
    },
    family: {
        title: "Familia",
        subtitle: "Donde nace la memoria",
    },
    business: {
        title: "Negocio",
        subtitle: "Historias que dan rostro a tu trabajo",
    },
    events: {
        title: "Eventos/Fiestas",
        subtitle: "Instantes que merecen volver a vivirse",
    },
    maternity: {
        title: "Maternidad",
        subtitle: "El comienzo de una historia de amor",
    },
    couples: {
        title: "Parejas",
        subtitle: "Dos almas, un mismo recuerdo",
    },
    pets: {
        title: "Mascotas",
        subtitle: "Amor que no necesita palabras",
    },
};

const { sessionName } = Astro.params;

let title = "";
let subtitle = "";

title = titlesLayout[sessionName as keyof typeof titlesLayout].title;
subtitle = titlesLayout[sessionName as keyof typeof titlesLayout].subtitle;

const values = [
    "one",
    "two",
    "three",
    "four",
    "five",
    "one",
    "two",
    "three",
    "four",
    "five",
];
const images = values.map((val) => `/gallery/webp/${sessionName}-${val}.webp`);
---

<LayoutGallery title={title} subtitle={subtitle}>
    {/* <GalleryComponent sessionName={sessionName} client:load /> */}

    <section class="masonry-gallery">
        {
            images.map((img, index) => (
                <a
                    href={img}
                    class="glightbox masonry-item"
                    data-aos="fade-up"
                    data-aos-delay={index * 100}
                    data-gallery={`gallery-${sessionName}`}
                    data-title={`${title} - Toma ${index + 1}`}
                    data-description={`Capturando momentos inolvidables en nuestra sesión de ${title}.`}
                >
                    <img
                        src={img}
                        alt={`Fotografía de ${title}`}
                        loading="lazy"
                    />
                    <div class="masonry-overlay">
                        <span class="view-text">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />
                            </svg>
                        </span>
                    </div>
                </a>
            ))
        }
    </section>
</LayoutGallery>

<script>
    import GLightbox from "glightbox";
    import "glightbox/dist/css/glightbox.min.css";

    document.addEventListener("DOMContentLoaded", () => {
        const lightbox = GLightbox({
            selector: ".glightbox",
            touchNavigation: true,
            loop: true,
            zoomable: true,
            descPosition: "bottom",
        });
    });
</script>
