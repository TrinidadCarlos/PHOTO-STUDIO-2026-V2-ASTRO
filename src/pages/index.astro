---
import Layout from "@layouts/Layout.astro";
import "@styles/pages/home.css";

import photoOne from "@assets/img/generic/photo-one.jpg";
import photoTwo from "@assets/img/generic/photo-two.jpg";
import photoThree from "@assets/img/generic/photo-three.jpg";
import photoFour from "@assets/img/generic/photo-four.jpg";
import photoFive from "@assets/img/generic/photo-five.jpg";
import ourImage from "@assets/img/generic/our.jpg";

import { Image } from "astro:assets";
---

<Layout title="test" description="test description">
  <section class="hero">
    <!-- Slider main container -->
    <div class="swiper swiper-hero">
      <!-- Additional required wrapper -->
      <div class="swiper-wrapper">
        <!-- Slides -->
        <div class="swiper-slide slide-hero">
          <div class="hero-text">
            <div>
              <h2>Bodas</h2>
              <p>Capturando momentos inolvidables</p>
            </div>
          </div>
          <figure class="hero-img">
            <Image src={photoOne} alt="Imagen de portada uno" loading="lazy" />
          </figure>
        </div>

        <div class="swiper-slide slide-hero">
          <div class="hero-text">
            <div>
              <h2>Sesiones en estudio</h2>
              <p>Capturando momentos inolvidables</p>
            </div>
          </div>
          <figure class="hero-img">
            <Image src={photoTwo} alt="Imagen de portada uno" loading="lazy" />
          </figure>
        </div>

        <div class="swiper-slide slide-hero">
          <div class="hero-text">
            <div>
              <h2>Sesiones en exterior</h2>
              <p>Capturando momentos inolvidables</p>
            </div>
          </div>
          <figure class="hero-img">
            <Image
              src={photoThree}
              alt="Imagen de portada uno"
              loading="lazy"
            />
          </figure>
        </div>

        <div class="swiper-slide slide-hero">
          <div class="hero-text">
            <div>
              <h2>Comuniones</h2>
              <p>Capturando momentos inolvidables</p>
            </div>
          </div>
          <figure class="hero-img">
            <Image src={photoFive} alt="Imagen de portada uno" loading="lazy" />
          </figure>
        </div>

        <div class="swiper-slide slide-hero">
          <div class="hero-text">
            <div>
              <h2>Y más...</h2>
              <p>Capturando momentos inolvidables</p>
            </div>
          </div>
          <figure class="hero-img">
            <Image src={photoFour} alt="Imagen de portada uno" loading="lazy" />
          </figure>
        </div>
        ...
      </div>
      <!-- If we need pagination -->
      <div class="swiper-pagination"></div>

      <!-- If we need navigation buttons -->
      <!-- <div class="swiper-button-prev"></div>
            <div class="swiper-button-next"></div> -->

      <!-- If we need scrollbar -->
      <!-- <div class="swiper-scrollbar"></div> -->
    </div>
  </section>

  <!-- ABOUT SECTION -->
  <section class="about-section">
    <div class="about-container">
      <div class="about-text" data-aos="fade-up" data-aos-duration="1000">
        <span class="subtitle">Conócenos</span>
        <h2 class="title">El arte de capturar emociones</h2>
        <p>
          En nuestro estudio, no solo tomamos fotografías; inmortalizamos
          historias. Con años de experiencia en el mundo visual, nuestro enfoque
          combina técnica, pasión y una sensibilidad única para reflejar tu
          verdadera esencia en cada toma.
        </p>
        <p>
          Desde la luz perfecta hasta el encuadre más sutil, cuidamos cada
          detalle para que tus recuerdos perduren con la máxima calidad y
          elegancia.
        </p>
        <a href="/about" class="btn-primary">Descubre más</a>
      </div>
      <figure
        class="about-image"
        data-aos="fade-up"
        data-aos-delay="200"
        data-aos-duration="1000"
      >
        <div class="image-wrapper">
          <Image src={ourImage} alt="Fotógrafo trabajando" loading="lazy" />
          <!-- <div class="experience-badge">
            <span class="years">+10</span>
            <span class="text">Años de <br/>Experiencia</span>
          </div> -->
        </div>
      </figure>
    </div>
  </section>

  <!-- SERVICES OVERVIEW SECTION -->
  <section class="services-overview">
    <div class="services-header" data-aos="fade-up">
      <span class="subtitle">Nuestros Servicios</span>
      <h2 class="title">Especialidades Fotográficas</h2>
    </div>

    <div class="services-grid">
      <div class="service-card" data-aos="fade-up" data-aos-delay="100">
        <figure class="card-image">
          <Image src={photoOne} alt="Fotografía de Bodas" loading="lazy" />
        </figure>
        <div class="card-content">
          <h3>Bodas</h3>
          <p>
            Cobertura completa para el día más importante de tu vida, cuidando
            cada detalle.
          </p>
          <span class="card-link">Ver más &rarr;</span>
        </div>
      </div>

      <div class="service-card" data-aos="fade-up" data-aos-delay="200">
        <figure class="card-image">
          <Image src={photoTwo} alt="Fotografía de Estudio" loading="lazy" />
        </figure>
        <div class="card-content">
          <h3>Estudio</h3>
          <p>
            Retratos profesionales, moda y familia con iluminación y fondos
            perfectos.
          </p>
          <span class="card-link">Ver más &rarr;</span>
        </div>
      </div>

      <div class="service-card" data-aos="fade-up" data-aos-delay="300">
        <figure class="card-image">
          <Image src={photoThree} alt="Fotografía en Exterior" loading="lazy" />
        </figure>
        <div class="card-content">
          <h3>Exterior</h3>
          <p>
            Aprovechamos la luz natural en locaciones espectaculares para tus
            sesiones.
          </p>
          <span class="card-link">Ver más &rarr;</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="cta-section">
    <div class="cta-content" data-aos="zoom-in">
      <h2>¿Listo para crear recuerdos inolvidables?</h2>
      <p>
        Reserva tu sesión fotográfica hoy mismo y déjanos capturar tu mejor
        versión.
      </p>
      <a href="/contact-booking" class="btn-secondary">Agendar Sesión</a>
    </div>
  </section>
</Layout>

<script>
  import Swiper from "swiper/bundle";
  // @ts-ignore: no type declarations for this side-effect CSS import
  // import "swiper/css/bundle";
  const swiper = new Swiper(".swiper-hero", {
    // Optional parameters
    // direction: "vertical",
    effect: "fade",
    fadeEffect: {
      crossFade: true,
    },
    loop: true,
    autoplay: {
      delay: 2500,
    },

    // If we need pagination
    pagination: {
      el: ".swiper-pagination",
    },

    // Navigation arrows
    // navigation: {
    //   nextEl: '.swiper-button-next',
    //   prevEl: '.swiper-button-prev',
    // },

    // And if we need scrollbar
    // scrollbar: {
    //   el: ".swiper-scrollbar",
    // },
  });
</script>
