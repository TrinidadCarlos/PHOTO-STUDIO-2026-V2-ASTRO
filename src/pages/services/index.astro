---
import Layout from "@layouts/Layout.astro";
import "@styles/pages/services/homeServices.css";
import { routes } from "@utils/constants/routes";
import { Image } from "astro:assets";

import bussinessImage from "@assets/img/services/bussiness-one.jpg";
import familyImage from "@assets/img/services/family-one.jpg";
import petsImage from "@assets/img/services/pets-one.jpg";
import maternityImage from "@assets/img/services/maternity-one.jpg";
import eventsImage from "@assets/img/services/events-one.jpg";
import couplesImage from "@assets/img/services/couples-one.jpg";
import religiousImage from "@assets/img/services/religious-one.jpg";
import weddingImage from "@assets/img/services/wedding-one.jpg";
import emptyImage from "@assets/img/generic/services-menu.jpg";

const serviceRoutes = routes.filter((router) => router.basePath == "/services");

const images = {
    "family-one": familyImage,
    "pets-one": petsImage,
    "bussiness-one": bussinessImage,
    "events-one": eventsImage,
    "couples-one": couplesImage,
    "religious-one": religiousImage,
    "wedding-one": weddingImage,
    "maternity-one": maternityImage,
};
---

<Layout>
    <main class="main-service-page">
        <!-- HERO SECTION -->
        <section class="page-hero t-padding-header" data-aos="fade-down">
            <div class="page-hero-content">
                <span class="page-subtitle">Portafolio Profesional</span>
                <h2 class="t-page-titles">SESIONES</h2>
                <p>
                    Nuestros servicios incluyen: Fotografía, video y tomas con dron
                </p>
            </div>
        </section>

        <!-- SERVICES GRID OVERLAP -->
        <section class="page-overlap-content services-gallery-grid" data-aos="fade-up" data-aos-delay="200">
            {
                serviceRoutes.map((routes) =>
                    routes.routes.map(
                        (route, index) =>
                            route.path !== "" && (
                                <a
                                    href={`${routes.basePath}${route.path}`}
                                    class={`service-bento-card bento-card-${index}`}
                                >
                                    <figure>
                                        <Image
                                            src={
                                                route?.imgName
                                                    ? images[
                                                          route.imgName as keyof typeof images
                                                      ]
                                                    : emptyImage
                                            }
                                            alt={`Sesión fotográfica de ${route.name}`}
                                            loading="lazy"
                                        />
                                    </figure>
                                    <div class="bento-content">
                                        <h3>{route.name}</h3>
                                        <span class="view-details">Ver detalles &rarr;</span>
                                    </div>
                                </a>
                            )
                    )
                )
            }
        </section>
    </main>
</Layout>
